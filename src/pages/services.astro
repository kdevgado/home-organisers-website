---
import Base from "../layouts/Base.astro";
const page = {
  title: "Services — Shepparton Home Organising",
  description: "Practical, beautiful organising for every kind of home life.",
};
---

<Base {...page} canonical="https://homeorg.com.au/services">
  <section class="container services-hero">
    <h1>Services</h1>
    <p class="lead">
      Systems that fit your life. We design spaces that are easy to keep, easy
      to love, and easy to share.
    </p>
  </section>

  <section class="container">
    <div class="service-grid">
      <!-- Space Efficiency -->
      <article class="service-card">
        <div class="media">
          <a href="/services/space-efficiency">
            <img
              loading="lazy"
              width="720"
              height="480"
              src="/images/services/spaceefficiency.png"
              alt="Shelves and containers arranged for maximum space efficiency"
            /></a
          >
          <span class="badge-icon" aria-hidden="true">
            <!-- Shelves icon -->
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M3 6h18M3 12h18M3 18h18"></path><path d="M6 6v12M18 6v12"
              ></path>
            </svg>
          </span>
        </div>
        <div class="body">
          <h2>Space Efficiency</h2>
          <p>
            Declutter and configure every inch to free up space utilising zoning
            and flow patterns.
          </p>
          <p>
            <a class="btn" href="/services/space-efficiency"
              >Explore Space Efficiency</a
            >
          </p>
        </div>
      </article>

      <!-- Specialised Needs Support -->
      <article class="service-card">
        <div class="media">
          <a href="/services/specialised">
            <img
              loading="lazy"
              width="720"
              height="480"
              src="/images/services/specialised.png"
              alt="Clear pathways and labelled storage for accessibility"
            /></a
          >

          <span class="badge-icon" aria-hidden="true">
            <!-- Heart/support icon -->
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M12 21s-6-3.3-6-8a4 4 0 0 1 7-2 4 4 0 0 1 7 2c0 4.7-6 8-6 8z"
              ></path>
            </svg>
          </span>
        </div>
        <div class="body">
          <h2>Specialised Needs Support</h2>
          <p>
            Gentle, practical setups for accessibility and independence, with
            NDIS support collaboration.
          </p>
          <p>
            <a class="btn" href="/services/specialised"
              >Specialised Needs Support</a
            >
          </p>
        </div>
      </article>

      <!-- Technical Approach -->
      <article class="service-card">
        <div class="media">
          <a href="/services/technical-approach">
            <img
              loading="lazy"
              width="720"
              height="480"
              src="/images/services/technical.png"
              alt="Measured storage plan with containers and labels"
            />
          </a>
          <span class="badge-icon" aria-hidden="true">
            <!-- Ruler/plan icon -->
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="3" y="4" width="18" height="12" rx="2" ry="2"></rect>
              <path d="M7 8h0M11 8h0M15 8h0M19 8h0"></path><path d="M7 12h10"
              ></path>
            </svg>
          </span>
        </div>
        <div class="body">
          <h2>Technical Approach</h2>
            <p>
              Function-based design: macro/micro containers, traffic paths and reach
              analysis.
            </p>
          <p>
            <a class="btn" href="/services/technical-approach"
              >Explore Tech Approach</a
            >
          </p>
        </div>
      </article>

      <!-- Goal - Setting -->
      <article class="service-card">
        <div class="media">
          <a href="/services/fitstyle">
            <img
              loading="lazy"
              width="720"
              height="480"
              src="/images/services/fitstyle.png"
              alt="Beautifully styled storage that is also functional"
            />
          </a>
          <span class="badge-icon" aria-hidden="true">
            <!-- Sparkle icon -->
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M12 3l2.5 5.5L20 11l-5.5 2.5L12 19l-2.5-5.5L4 11l5.5-2.5L12 3z"
              ></path>
              <path d="M5 20h.01M19 20h.01"></path>
            </svg>
          </span>
        </div>
        <div class="body">
          <h2>Fit for purpose &amp; style</h2>
            <p>
              Systems that look good and practical using colours and elements matched
              to your taste.
            </p>
          <p>
            <a class="btn" href="/services/fitstyle"
              >Fit for purpose &amp; style</a
            >
          </p>
        </div>
      </article>

      <!-- Goal - Setting -->
      <article class="service-card">
        <div class="media">
          <a href="/services/goal-setting">
            <img
              loading="lazy"
              width="720"
              height="480"
              src="/images/services/goal-setting.png"
              alt="Shared home storage with colour-coded baskets"
            />
          </a>
          <span class="badge-icon" aria-hidden="true">
            <!-- People/home icon -->
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M3 10.5l9-7 9 7"></path><path
                d="M5 10v9a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-9"></path>
              <path d="M8 20v-5a4 4 0 0 1 8 0v5"></path>
            </svg>
          </span>
        </div>
        <div class="body">
          <h2>Goal - Setting</h2>
            <p>
              Reduce friction and optimise movement and views, and increase focus and
              comfort.
            </p>
          <p>
            <a class="btn" href="/services/goal-setting"
              >Explore Goal - Setting</a
            >
          </p>
        </div>
      </article>
    </div>
  </section>

  <section class="container steps">
    <h2>How it works</h2>
    <ol class="step-list">
      <li>
        <strong>Free phone chat (15 min):</strong> Your goals, your space, your timeline.
      </li>
      <li>
        <strong>In-home or virtual assessment:</strong> Simple plan + estimate.
      </li>
      <li>
        <strong>Session day:</strong> We work together with a calm, clear process.
      </li>
      <li>
        <strong>Waste & donations:</strong> Where possible, managed for you.
      </li>
      <li>
        <strong>Simple upkeep guide:</strong> A few habits so it stays tidy.
      </li>
    </ol>
    <p><a class="btn" href="/contact">Get your tailored quote</a></p>
  </section>

  <section class="container steps">
    <h2>Service Areas</h2>
    <p>
      Proudly based in <strong>Shepparton, VIC</strong>, serving the <strong
        >Goulburn Valley</strong
      > and surrounding shires: <strong
        >Mitchell, Murrindindi, Moira, Strathbogie</strong
      > — plus nearby towns and rural properties.
    </p>
    <p>
      Regular visits to <em
        >Mooroopna, Tatura, Nagambie, Euroa, Benalla, Seymour, Alexandra,
        Kilmore, Cobram, Yarrawonga</em
      > and more.
    </p>
    <p>
      Not sure if I travel to you? <a class="link" href="/contact"
        >Ask about your location</a
      >.
    </p>
  </section>
</Base>

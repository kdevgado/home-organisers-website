---
import Base from "../../layouts/Base.astro";
import "../../../public/styles/services.css";
const page = {
  title: "Fit for purpose & style — Shepparton Home Organising",
  description: "Organising systems that balance functionality and aesthetics, matched to your space, taste, and budget."
};
---
<Base {...page} canonical="https://homeorg.com.au/services/fitstyle" href="/styles/services.css">
  <section class="container services-hero">
    <h1>Fit for purpose & style</h1>
    <p class="lead">Organising systems that balance functionality and aesthetics, matched to your space, taste, and budget.</p>

    <div class="tabs">
      <button class="tab is-active" data-target="entry">Entryway</button>
      <button class="tab" data-target="living">Living Areas</button>
      <button class="tab" data-target="bedroom">Bedrooms</button>
    </div>

    <div class="tab-panels">
      <div id="entry" class="tab-panel is-active">
        <img src="/images/services/fitstyle.png" alt="Welcoming entryway" />
        <h2>Entryway: first impressions count</h2>
        <ul class="checklist">
          <li>Decluttered, fresh, inviting.</li>
          <li>Statement piece for impact.</li>
          <li>Warm lighting for welcome feel.</li>
        </ul>
      </div>
      <div id="living" class="tab-panel">
        <img src="/images/services/fitstyle.png" alt="Staged living room" />
        <h2>Living Areas: light & spacious</h2>
        <ul class="checklist">
          <li>Furniture arranged for flow.</li>
          <li>Neutral palette with accents.</li>
          <li>Decluttered surfaces and décor.</li>
        </ul>
      </div>
      <div id="bedroom" class="tab-panel">
        <img src="/images/services/fitstyle.png" alt="Staged bedroom" />
        <h2>Bedrooms: calm retreats</h2>
        <ul class="checklist">
          <li>Crisp bedding with cushions.</li>
          <li>Minimal personal items.</li>
          <li>Balanced layout for rest feel.</li>
        </ul>
      </div>
    </div>

    <div class="panel">
      <h3>What you get</h3>
      <ul class="pill-list">
        <li>Professional staging advice</li>
        <li>Hands-on setup</li>
        <li>Photo-ready presentation</li>
      </ul>
      <p><a class="btn" href="/contact">Book staging service</a></p>
    </div>
  </section>

  <script is:inline>
    const tabs = document.querySelectorAll('.tab');
    const panels = document.querySelectorAll('.tab-panel');
    tabs.forEach(btn => btn.addEventListener('click', () => {
      tabs.forEach(b => b.classList.remove('is-active'));
      panels.forEach(p => p.classList.remove('is-active'));
      btn.classList.add('is-active');
      document.getElementById(btn.dataset.target).classList.add('is-active');
    }));
  </script>
</Base>

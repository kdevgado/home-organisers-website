---
import Base from "../layouts/Base.astro";
import BeforeAfterComponent from "../components/BeforeAfter.astro";
---

<Base title="Before & After — Real Home Transformations">
  <section class="container services-hero">
    <h1>Gallery</h1>
      <p>
        <strong>Real homes. Real results.</strong> Here's a peek at the kind of change
        simple systems can make.
      </p>
    <!-- 🎬 FEATURED VIDEO -->
    <section class="featured-video">
      <div class="featured-video__shell">
        <div class="featured-video__header">
          <p class="featured-video__kicker">Featured Transformation</p>
          <h2 class="featured-video__title">House Staging Walkthrough</h2>
          <p class="featured-video__desc">
            A quick look at how we create calm, functional spaces with simple systems.
          </p>
        </div>

        <button
          class="video-thumb featured-video__thumb"
          type="button"
          data-type="youtube"
          data-id="Yh1ooi1RGJc?si=866ILyPqrTb4yfrb"
          aria-label="Play house staging video"
        >
          <img src="/images/gallery/video-thumb.jpg" alt="Play house staging video" />
          <span class="featured-video__play" aria-hidden="true">
            <span class="featured-video__playIcon">▶</span>
            <span class="featured-video__playText">Play video</span>
          </span>
        </button>
      </div>
    </section>

    <h2 class="gallery-heading">House Staging</h2>

    <!-- 🖼️ GALLERY SECTION -->
    <div class="gallery">
      <!-- Mickelham -->
      <img src="/images/gallery/mickelham/4.jpg" alt=" organisation" />
      <img src="/images/gallery/mickelham/5.jpg" alt=" organisation" />
      <img src="/images/gallery/mickelham/1.jpg" alt=" organisation" />
      <img src="/images/gallery/mickelham/2.jpg" alt=" organisation" />
      <img src="/images/gallery/mickelham/3.jpg" alt=" organisation" />

      <img src="/images/gallery/mickelham/6.jpg" alt=" organisation" />
      <img src="/images/gallery/mickelham/7.jpg" alt=" organisation" />
      <img src="/images/gallery/mickelham/8.jpg" alt=" organisation" />
      <img src="/images/gallery/mickelham/9.jpg" alt=" organisation" />
      <img src="/images/gallery/mickelham/10.jpg" alt=" organisation" />
      <img src="/images/gallery/mickelham/11.jpg" alt=" organisation" />

      <!-- Sharehouse -->
      <img src="/images/gallery/sharehouse/1.jpg" alt="Closet organisation" />
      <img src="/images/gallery/sharehouse/2.jpg" alt="Closet organisation" />
      <img src="/images/gallery/sharehouse/3.jpg" alt="Closet organisation" />
      <img src="/images/gallery/sharehouse/4.jpg" alt="Closet organisation" />
      <img src="/images/gallery/sharehouse/5.jpg" alt="Closet organisation" />
      <img src="/images/gallery/sharehouse/6.jpg" alt="Closet organisation" />
      <img src="/images/gallery/sharehouse/7.jpg" alt="Closet organisation" />

      <!-- Mickelham -->
      <img src="/images/gallery/gladstone/1.jpg" alt=" organisation" />
      <img src="/images/gallery/gladstone/2.jpg" alt=" organisation" />
      <img src="/images/gallery/gladstone/3.jpg" alt=" organisation" />
      <img src="/images/gallery/gladstone/4.jpg" alt=" organisation" />

      <!-- Shepparton -->
      <img src="/images/gallery/shepparton/shelves.png" alt="Organised shelving in a Shepparton home" />
    </div>

    <!-- LIGHTBOX MODAL -->
    <div id="lightbox" class="lightbox hidden" aria-hidden="true">
      <span class="close" role="button" tabindex="0" aria-label="Close"
        >&times;</span
      >

      <!-- Dynamic content goes here (image OR video) -->
      <div class="lightbox-content" id="lightboxContent"></div>

      <button class="prev" aria-label="Previous">&#10094;</button>
      <button class="next" aria-label="Next">&#10095;</button>
    </div>

    <div class="before-after-intro">
      <p class="featured-video__kicker">Before & After</p>
      <h2>Practical transformations</h2>
      <p>
        Small changes, clearer zones, and systems that make the space easier to keep tidy.
      </p>
    </div>

    <div class="ba-grid">
      <BeforeAfterComponent
        before="/images/gallery/before-after/pantry before.jpg"
        after="/images/gallery/before-after/pantry.jpg"
        alt="Pantry organised with labelled containers"
        title="Pantry reset"
        description="Labels and clear containers make everyday items easier to see and reach."
        labelBefore="Before"
        labelAfter="After"
        start={55}
      />

      <BeforeAfterComponent
        before="/images/gallery/before-after/pantry_corner_before2.jpg"
        after="/images/gallery/before-after/pantry_corner.jpg"
        alt="Pantry organised with labelled containers"
        title="Corner pantry"
        description="A busy corner becomes calmer with grouped categories and better shelf flow."
        labelBefore="Before"
        labelAfter="After"
        start={55}
      />

      <BeforeAfterComponent
        before="/images/gallery/before-after/kitchen_before.png"
        after="/images/gallery/before-after/kitchen_after.jpg"
        alt="Kitchen bench and storage area after organising"
        title="Kitchen surfaces"
        description="Benches and storage zones are cleared so the room feels lighter and easier to use."
        labelBefore="Before"
        labelAfter="After"
        start={50}
      />

      <BeforeAfterComponent
        before="/images/gallery/before-after/kitchen2_before.png"
        after="/images/gallery/before-after/kitchen2_after.jpg"
        alt="Kitchen storage area after organising"
        title="Kitchen storage"
        description="A more intentional layout helps the essentials sit where they naturally belong."
        labelBefore="Before"
        labelAfter="After"
        start={50}
      />

      <BeforeAfterComponent
        before="/images/gallery/before-after/kitchen3_before.png"
        after="/images/gallery/before-after/kitchen3_after.jpg"
        alt="Kitchen area after organising"
        title="Kitchen refresh"
        description="The finished space keeps the practical items close while reducing visual clutter."
        labelBefore="Before"
        labelAfter="After"
        start={50}
      />
    </div>

    <p class="muted">
      More transformations coming soon. Each session focuses on practical,
      maintainable changes — not show-home perfection.
    </p>
    <p>
      <a class="btn" href="/contact"
        >Be the next transformation — book your session</a
      >
    </p>
  </section>

  <!-- 💡 GALLERY & LIGHTBOX SCRIPT -->
  <script>
  document.addEventListener("DOMContentLoaded", () => {
    const galleryImages = Array.from(
      document.querySelectorAll<HTMLImageElement>(".gallery > img") // ✅ skips thumbnail img
    );

    const videoThumb = document.querySelector<HTMLButtonElement>(".video-thumb");

    const lightbox = document.getElementById("lightbox");
    const lightboxContent = document.getElementById("lightboxContent");
    const closeBtn = document.querySelector<HTMLSpanElement>(".close");
    const nextBtn = document.querySelector<HTMLButtonElement>(".next");
    const prevBtn = document.querySelector<HTMLButtonElement>(".prev");

    if (!lightbox || !lightboxContent || !closeBtn || !nextBtn || !prevBtn) return;

    type Item =
      | { type: "youtube"; id: string }
      | { type: "image"; src: string; alt: string };

    const items: Item[] = [];

    // Video item (index 0)
    if (videoThumb?.dataset.id) {
      items.push({ type: "youtube", id: videoThumb.dataset.id });
    }

    // Image items (index 1..n)
    galleryImages.forEach((img) => {
      items.push({ type: "image", src: img.src, alt: img.alt || "Expanded view" });
    });

    if (items.length === 0) return;

    let currentIndex = 0;

    const openLightbox = () => {
      lightbox.classList.remove("hidden");
      lightbox.setAttribute("aria-hidden", "false");
    };

    const closeLightbox = () => {
      lightbox.classList.add("hidden");
      lightbox.setAttribute("aria-hidden", "true");
      lightboxContent.innerHTML = ""; // ✅ stops YouTube playback
    };

    const renderItem = (index: number) => {
      const item = items[index];
      lightboxContent.innerHTML = "";

      if (item.type === "youtube") {
        const wrap = document.createElement("div");
        wrap.className = "lightbox-video";

        const iframe = document.createElement("iframe");
        iframe.src = `https://www.youtube.com/embed/${item.id}?autoplay=1&rel=0&modestbranding=1`;
        iframe.title = "YouTube video";
        iframe.allow =
          "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture";
        iframe.allowFullscreen = true;

        wrap.appendChild(iframe);
        lightboxContent.appendChild(wrap);
        return;
      }

      const img = document.createElement("img");
      img.className = "lightbox-image";
      img.src = item.src;
      img.alt = item.alt;
      lightboxContent.appendChild(img);
    };

    const nextItem = () => {
      currentIndex = (currentIndex + 1) % items.length;
      renderItem(currentIndex);
    };

    const prevItem = () => {
      currentIndex = (currentIndex - 1 + items.length) % items.length;
      renderItem(currentIndex);
    };

    // Click video tile => open index 0
    videoThumb?.addEventListener("click", () => {
      currentIndex = 0;
      openLightbox();
      renderItem(currentIndex);
    });

    // Click image => open correct index in items
    galleryImages.forEach((img, index) => {
      img.addEventListener("click", () => {
        const hasVideo = items[0]?.type === "youtube";
        currentIndex = hasVideo ? index + 1 : index;
        openLightbox();
        renderItem(currentIndex);
      });
    });

    closeBtn.addEventListener("click", closeLightbox);
    nextBtn.addEventListener("click", nextItem);
    prevBtn.addEventListener("click", prevItem);

    lightbox.addEventListener("click", (e) => {
      if (e.target === lightbox) closeLightbox();
    });

    window.addEventListener("keydown", (e) => {
      if (lightbox.classList.contains("hidden")) return;
      if (e.key === "ArrowRight") nextItem();
      if (e.key === "ArrowLeft") prevItem();
      if (e.key === "Escape") closeLightbox();
    });
  });
</script>

<style>
  .before-after-intro {
    max-width: 760px;
    margin: 3.5rem auto 1.25rem;
    text-align: center;
  }

  .before-after-intro h2 {
    margin: 0 0 .45rem;
  }

  .before-after-intro p:last-child {
    margin: 0 auto;
    color: var(--ink-soft);
  }

  .ba-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.1rem;
    max-width: 1180px;
    margin-inline: auto;
  }

  @media (max-width: 850px) {
    .ba-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

</Base>

---
import Base from "../layouts/Base.astro";
---

<Base title="Book a Consultation - Shepparton Home Organising">
  <section class="contact page">
    <div class="container narrow">
      <h1>Book a 30-minute Consultation</h1>
      <p>
        Pick a date and an available time below. You'll receive an instant
        calendar invite.
      </p>

      <form
        id="booking-form"
        class="booking-form"
        novalidate
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
      >
        <div class="grid-2">
          <label>
            Name
            <input type="text" name="name" required />
          </label>
          <label>
            Email
            <input type="email" name="email" required />
          </label>
        </div>

        <div class="grid-2">
          <label>
            Phone
            <input type="tel" name="phone" required />
          </label>
          <label>
            Suburb/Town (optional)
            <input type="text" name="suburb" />
          </label>
        </div>

        <div class="grid-2">
          <label>
            Preferred method of contact
            <select name="contact_method" required>
              <option value="">Select an option</option>
              <option value="Phone">Phone</option>
              <option value="Email">Email</option>
              <option value="SMS">SMS</option>
            </select>
          </label>

          <label>
            How did you find us?
            <select name="referral_source" required>
              <option value="">Select an option</option>
              <option value="Google">Google</option>
              <option value="Website">Website</option>
              <option value="Facebook">Facebook</option>
              <option value="Instagram">Instagram</option>
              <option value="Friend/Family">Friend / Family</option>
              <option value="Referral (NDIS/Agency)"
                >Referral (NDIS / Agency)</option
              >
              <option value="Other">Other</option>
            </select>
          </label>
        </div>

        <fieldset class="service-fieldset">
          <legend>Which service(s) are you interested in?</legend>

          <div class="service-chips">
            <button type="button" class="chip" data-value="Home Decluttering">
              Home Decluttering
            </button>
            <button
              type="button"
              class="chip"
              data-value="Practical Organising"
            >
              Practical Organising
            </button>
            <button
              type="button"
              class="chip"
              data-value="Homeshare and Co-living"
            >
              Homeshare & Co-living
            </button>
            <button
              type="button"
              class="chip"
              data-value="Moving Houses & Setting Up"
            >
              Moving Houses & Setting Up
            </button>
            <button
              type="button"
              class="chip"
              data-value="Staging to Sell/Lease"
            >
              Staging to Sell / Lease
            </button>
            <button
              type="button"
              class="chip"
              data-value="Not sure yet"
              data-default="true"
            >
              Not sure yet
            </button>
          </div>

          <!-- hidden input to submit values -->
          <input type="hidden" name="services" id="servicesInput" />
        </fieldset>

        <label>
          Brief notes (optional)
          <textarea
            name="message"
            rows="5"
            placeholder="Describe in a few words the space requiring organisation"
          ></textarea>
        </label>

        <div class="grid-2">
          <label
            >Consultation preferred date
            <input
              type="text"
              id="booking-date"
              name="booking_date"
              required
              placeholder="Choose a date"
              autocomplete="off"
              inputmode="none"
            />
          </label>
        </div>

        <button class="btn" id="book-btn" type="submit"
          >Book consultation</button
        >

        <p class="muted small">
          You'll get an email confirmation with a calendar invite. Times shown
          use your local timezone.
        </p>
        <p class="muted small">
          This is a judgement-free service. Your privacy is always respected.
        </p>
      </form>
    </div>
  </section>

  <!-- Toast notifications (re-use your existing styles/behavior) -->
  <div id="toast" role="status" aria-live="polite"></div>

  <!-- Calendar (Flatpickr) -->
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css"
  />
  <script src="https://cdn.jsdelivr.net/npm/flatpickr" defer></script>

  <!-- Booking behavior -->
  <script src="/js/contact.js" type="module" defer></script>
</Base>

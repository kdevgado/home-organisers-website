---
import Base from "../layouts/Base.astro";
const page = {
  title: "4C Steps Approach — Shepparton Home Organising",
  description:
    "Our simple 4C method: Collect, Cut, Contain, and Classify — creating calm, easy-to-maintain organising systems.",
};
---

<Base {...page} canonical="https://homeorg.com.au/4c-steps-approach">
  <section class="container narrow">
    <h1>4C Steps Approach</h1>
    <p class="lead">
      A simple, proven method we use to declutter and organise your home in a way
      that’s easy to maintain.
    </p>
  </section>

  <!-- Home Org 4Cs Approach Section -->
  <section class="container panel home-4cs">
    <h2>Home Org 4Cs Approach</h2>
    <p class="muted">
      A simple, proven method we use to bring clarity, calm, and systems that last.
    </p>

    <div class="four-cs-grid">
      <article class="card">
        <h3>1. Collect</h3>
        <p>
          I bring large boxes to gather and group similar items together, so we can
          clearly see what you own.
        </p>
      </article>

      <article class="card">
        <h3>2. Cut</h3>
        <p>
          I help you decide what to keep, donate, or discard — gently, respectfully,
          and without judgement.
        </p>
      </article>

      <article class="card">
        <h3>3. Contain</h3>
        <p>
          Items are organised using your existing containers or affordable options
          I can provide, tailored to your space and lifestyle.
        </p>
      </article>

      <article class="card">
        <h3>4. Classify</h3>
        <p>
          Containers are labelled and arranged into a visual system that’s easy for
          you and your household to maintain long-term.
        </p>
      </article>
    </div>
  </section>

  <!-- Clutterbug Section -->
  <section class="container">
    <div class="feature-grid">
      <!-- Butterfly -->
      <article id="butterfly" class="card service-card">
        <div class="icon-wrap" aria-hidden="true">
          <img
            src="/images/bugs/butterfly.jpg"
            alt="Butterfly illustration"
            class="service-icon"
          />
        </div>
        <h2>Butterfly</h2>
        <p>
          A big-picture, visual organizer who needs quick, simple, open systems
          (like baskets, trays, and labels) to avoid overwhelm.
        </p>
      </article>

      <!-- Bee -->
      <article id="bee" class="card service-card">
        <div class="icon-wrap" aria-hidden="true">
          <img
            src="/images/bugs/bee.jpg"
            alt="Bee illustration"
            class="service-icon"
          />
        </div>
        <h2>Bee</h2>
        <p>
          A detail-oriented visual organizer who thrives on lots of
          micro-categories, labels, and clearly visible systems to stay in
          control.
        </p>
      </article>

      <!-- Ladybug -->
      <article id="ladybug" class="card service-card">
        <div class="icon-wrap" aria-hidden="true">
          <img
            src="/images/bugs/ladybug.jpg"
            alt="Ladybug illustration"
            class="service-icon"
          />
        </div>
        <h2>Ladybug</h2>
        <p>
          Loves a space that looks calm and tidy, but prefers to hide items in
          closed bins, drawers, or cabinets with flexible categories inside.
        </p>
      </article>

      <!-- Cricket -->
      <article id="cricket" class="card service-card">
        <div class="icon-wrap" aria-hidden="true">
          <img
            src="/images/bugs/cricket.jpg"
            alt="Cricket illustration"
            class="service-icon"
          />
        </div>
        <h2>Cricket</h2>
        <p>
          A detail-focused hidden organizer who prefers everything tucked neatly
          away in closed, highly structured systems like files, dividers, and
          labeled boxes.
        </p>
      </article>
    </div>
  </section>

  <section class="container steps">
    <p class="small muted">
      The Clutterbug Organising Styles are created by
      <a
        href="https://clutterbug.me"
        class="link"
        target="_blank"
        rel="noopener"
      >
        Cassandra Aarssen
      </a>. Used here with full credit to the original creator.
    </p>
  </section>

  <section class="container steps">
    <h2>How it works</h2>
    <ol class="step-list">
      <li>
        <strong>Free phone chat (15 min):</strong> Your goals, your space, your timeline.
      </li>
      <li>
        <strong>In-home or virtual assessment:</strong> Simple plan + estimate.
      </li>
      <li>
        <strong>Session day:</strong> We work together with a calm, clear process.
      </li>
      <li>
        <strong>Waste & donations:</strong> Where possible, managed for you.
      </li>
      <li>
        <strong>Simple upkeep guide:</strong> A few habits so it stays tidy.
      </li>
    </ol>
    <p><a class="btn" href="/contact">Get your tailored quote</a></p>
  </section>

  <section class="container steps">
    <h2>Service Areas</h2>
    <p>
      Proudly based in <strong>Shepparton, VIC</strong>, serving the <strong
        >Goulburn Valley</strong
      > and surrounding shires: <strong
        >Mitchell, Murrindindi, Moira, Strathbogie</strong
      > — plus nearby towns and rural properties.
    </p>
    <p>
      Regular visits to <em
        >Mooroopna, Tatura, Nagambie, Euroa, Benalla, Seymour, Alexandra,
        Kilmore, Cobram, Yarrawonga</em
      > and more.
    </p>
    <p>
      Not sure if I travel to you? <a class="link" href="/contact"
        >Ask about your location</a
      >.
    </p>
  </section>
</Base>
